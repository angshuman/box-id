<Window x:Class="MachineLabel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Loaded="Window_Loaded">

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="⚙️ Settings..." Click="Settings_Click" />
            <Separator />
            <MenuItem Header="📋 Copy Machine Name" Click="CopyName_Click" />
            <Separator />
            <MenuItem x:Name="mnuStartup" Header="🚀 Start with Windows" IsCheckable="True" Click="Startup_Click" />
            <Separator />
            <MenuItem Header="❌ Exit" Click="Exit_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="LabelBorder"
            CornerRadius="4"
            Padding="10,2"
            Cursor="Hand"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <TextBlock x:Name="LabelText"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   FontFamily="Segoe UI Emoji, Segoe UI, Arial"
                   TextTrimming="None" />
    </Border>
</Window>
